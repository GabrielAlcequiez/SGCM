@model SGCM.Web.ViewModels.Citas_Agenda.Medico.CompletarPerfilMedicoViewModel

@{
    ViewData["Title"] = "Completar Perfil";
    Layout = "_Layout";
}

<h1>Completar tu Perfil</h1>
<p class="text-muted">Por favor complete su información profesional para continuar.</p>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="CompletarPerfil">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

            <div class="mb-3">
                <label asp-for="Nombre" class="form-label"></label>
                <input asp-for="Nombre" class="form-control" />
                <span asp-validation-for="Nombre" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Apellido" class="form-label"></label>
                <input asp-for="Apellido" class="form-control" />
                <span asp-validation-for="Apellido" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Telefono" class="form-label"></label>
                <input asp-for="Telefono" class="form-control" />
                <span asp-validation-for="Telefono" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="EspecialidadId" class="form-label"></label>
                <select asp-for="EspecialidadId" class="form-select">
                    <option value="">-- Seleccionar Especialidad --</option>
                    @foreach (var especialidad in Model.EspecialidadesDisponibles)
                    {
                        <option value="@especialidad.Id">@especialidad.Nombre</option>
                    }
                </select>
                <span asp-validation-for="EspecialidadId" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Exequatur" class="form-label"></label>
                <input asp-for="Exequatur" class="form-control" />
                <span asp-validation-for="Exequatur" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <input type="submit" value="Guardar y Continuar" class="btn btn-primary" />
                <a asp-controller="Auth" asp-action="CancelarRegistro" class="btn btn-secondary ms-2">Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}