@model SGCM.Web.ViewModels.Citas_Agenda.Cita.CrearCitaViewModel

@{
    ViewData["Title"] = "Crear Cita";
    Layout = "_Layout";
}

<h1>Crear Cita</h1>
<hr />
<div class="row">
    <div class="col-md-8">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

            <div class="mb-3">
                <label asp-for="MedicoId" class="form-label"></label>
                <select asp-for="MedicoId" class="form-select" id="MedicoId">
                    <option value="">-- Seleccionar Médico --</option>
                    @foreach (var medico in Model.MedicosDisponibles)
                    {
                        <option value="@medico.Id">@medico.NombreCompleto</option>
                    }
                </select>
                <span asp-validation-for="MedicoId" class="text-danger"></span>
            </div>

            <div class="mb-3" id="divFranjasHorarias" style="display:none;">
                <label class="form-label fw-bold">Seleccione un horario disponible:</label>
                <div id="listaFranjas" class="mb-3"></div>
                
                <select id="FranjaId" class="form-select">
                    <option value="">-- Seleccionar horario --</option>
                </select>
            </div>

            <div class="mb-3" id="divCitaSeleccionada" style="display:none;">
                <div class="alert alert-success d-flex justify-content-between align-items-center">
                    <div>
                        <strong>✓ Cita seleccionada:</strong> 
                        <span id="txtCitaSeleccionada"></span>
                    </div>
                    <button type="button" class="btn btn-sm btn-outline-secondary" onclick="cambiarFranja()">Cambiar</button>
                </div>
            </div>

            <input type="hidden" asp-for="FechaHora" id="FechaHora" />

            <div class="mb-3">
                <label asp-for="Motivo" class="form-label"></label>
                <textarea asp-for="Motivo" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Motivo" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <input type="submit" value="Crear Cita" class="btn btn-primary" id="btnCrear" disabled />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Volver a la lista</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        var franjasData = [];
        
        function cambiarFranja() {
            document.getElementById('divCitaSeleccionada').style.display = 'none';
            document.getElementById('FechaHora').value = '';
            document.getElementById('btnCrear').disabled = true;
            cargarDropdown();
        }

        function cargarDropdown() {
            var selectFranja = document.getElementById('FranjaId');
            selectFranja.innerHTML = '<option value="">-- Seleccionar horario --</option>';
            
            franjasData.forEach(function(f) {
                var fechaObj = new Date(f.fechaHora);
                var fechaStr = fechaObj.toLocaleDateString('es-ES', { weekday: 'short', day: 'numeric', month: 'short' });
                var horaInicio = f.horaInicio.substring(0, 5);
                var horaFin = f.horaFin.substring(0, 5);
                var option = document.createElement('option');
                option.value = f.fechaHora;
                option.textContent = `${fechaStr} ${horaInicio} - ${horaFin}`;
                selectFranja.appendChild(option);
            });
        }

        document.getElementById('MedicoId').addEventListener('change', async function() {
            var medicoId = this.value;
            var divFranjas = document.getElementById('divFranjasHorarias');
            var listaFranjas = document.getElementById('listaFranjas');
            
            document.getElementById('divCitaSeleccionada').style.display = 'none';
            document.getElementById('FechaHora').value = '';
            document.getElementById('btnCrear').disabled = true;
            
            if (!medicoId) {
                divFranjas.style.display = 'none';
                document.getElementById('FranjaId').innerHTML = '<option value="">-- Seleccionar horario --</option>';
                return;
            }
            
            try {
                var response = await fetch(`/Citas/ObtenerFranjasDisponibles?medicoId=${medicoId}`);
                var data = await response.json();
                
                if (data.error) {
                    listaFranjas.innerHTML = data.error;
                    listaFranjas.className = 'alert alert-warning';
                    divFranjas.style.display = 'block';
                    return;
                }
                
                if (data.franjas && data.franjas.length > 0) {
                    franjasData = [];
                    var diasAMostrar = 14; // 2 semanas
                    var fechaActual = new Date();

                    for (var i = 0; i < diasAMostrar; i++) {
                        var fechaIteracion = new Date(fechaActual);
                        fechaIteracion.setDate(fechaActual.getDate() + i);
                        
                        var diaSemanaIteracion = obtenerDiaSemana(fechaIteracion.getDay());
                        
                        data.franjas.forEach(function(f) {
                            if (f.diaSemana === diaSemanaIteracion) {
                                var anio = fechaIteracion.getFullYear();
                                var mes = String(fechaIteracion.getMonth() + 1).padStart(2, '0');
                                var dia = String(fechaIteracion.getDate()).padStart(2, '0');
                                var hora = f.horaInicio.substring(0, 5);
                                
                                franjasData.push({
                                    diaSemana: f.diaSemana,
                                    horaInicio: f.horaInicio,
                                    horaFin: f.horaFin,
                                    fechaHora: `${anio}-${mes}-${dia}T${hora}:00`
                                });
                            }
                        });
                    }
                    
                    if (franjasData.length === 0) {
                        listaFranjas.innerHTML = 'No hay horarios disponibles en las próximas 2 semanas.';
                        listaFranjas.className = 'alert alert-warning';
                        document.getElementById('FranjaId').innerHTML = '<option value="">-- No hay horarios --</option>';
                        divFranjas.style.display = 'block';
                        return;
                    }
                    
                    var html = `<h5 class="mb-3">${data.medicoNombre}</h5>`;
                    
                    var franjasOrdenadas = [...franjasData].sort(function(a, b) {
                        return new Date(a.fechaHora) - new Date(b.fechaHora);
                    });
                    
                    var franjasPorFecha = {};
                    franjasOrdenadas.forEach(function(f) {
                        var fechaKey = f.fechaHora.split('T')[0];
                        if (!franjasPorFecha[fechaKey]) {
                            franjasPorFecha[fechaKey] = [];
                        }
                        franjasPorFecha[fechaKey].push(f);
                    });
                    
                    Object.keys(franjasPorFecha).sort().forEach(function(fechaKey) {
                        var fechaObj = new Date(franjasPorFecha[fechaKey][0].fechaHora);
                        var fechaStr = fechaObj.toLocaleDateString('es-ES', { weekday: 'long', day: 'numeric', month: 'long' });
                        var franjas = franjasPorFecha[fechaKey];
                        
                        html += `<div class="card mb-2">`;
                        html += `<div class="card-header bg-primary text-white">${fechaStr}</div>`;
                        html += `<div class="card-body">`;
                        html += `<div class="d-flex flex-wrap gap-2">`;
                        franjas.forEach(function(f) {
                            var horaInicio = f.horaInicio.substring(0, 5);
                            var horaFin = f.horaFin.substring(0, 5);
                            html += `<span class="badge bg-success fs-6">${horaInicio} - ${horaFin}</span>`;
                        });
                        html += `</div></div></div>`;
                    });
                    
                    listaFranjas.innerHTML = html;
                    listaFranjas.className = '';
                    cargarDropdown();
                } else {
                    listaFranjas.innerHTML = 'No hay horarios disponibles para este médico en los próximos 30 días.';
                    listaFranjas.className = 'alert alert-warning';
                    document.getElementById('FranjaId').innerHTML = '<option value="">-- No hay horarios --</option>';
                }
                divFranjas.style.display = 'block';
            } catch (e) {
                listaFranjas.innerHTML = 'Error al cargar las disponibilidades.';
                listaFranjas.className = 'alert alert-danger';
                divFranjas.style.display = 'block';
            }
        });

        function obtenerDiaSemana(dia) {
            var dias = ['Domingo', 'Lunes', 'Martes', 'Miércoles', 'Jueves', 'Viernes', 'Sábado'];
            return dias[dia];
        }

        document.getElementById('FranjaId').addEventListener('change', function() {
            var selectedOption = this.options[this.selectedIndex];
            var fechaHora = selectedOption.value;
            var textoFrancha = selectedOption.text;
            
            if (!fechaHora) return;
            
            document.getElementById('divCitaSeleccionada').style.display = 'block';
            document.getElementById('txtCitaSeleccionada').innerText = textoFrancha;
            document.getElementById('FechaHora').value = fechaHora;
            document.getElementById('btnCrear').disabled = false;
            
            selectedOption.disabled = true;
            selectedOption.text = textoFrancha + ' (seleccionada)';
            this.value = '';
        });
    </script>
}
