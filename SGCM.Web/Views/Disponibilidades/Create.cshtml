@model SGCM.Web.ViewModels.Citas_Agenda.Disponibilidad.CrearDisponibilidadViewModel

@{
    ViewData["Title"] = "Crear Disponibilidad";
    Layout = "_Layout";
}

<h1>Crear Disponibilidad</h1>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

            <div class="mb-3">
                <label asp-for="MedicoId" class="form-label"></label>
                <select asp-for="MedicoId" class="form-select">
                    <option value="">-- Seleccionar Médico --</option>
                    @foreach (var medico in Model.MedicosDisponibles)
                    {
                        <option value="@medico.Id">@medico.NombreCompleto</option>
                    }
                </select>
                <span asp-validation-for="MedicoId" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="DiaSemana" class="form-label"></label>
                <select asp-for="DiaSemana" class="form-select">
                    <option value="">-- Seleccionar Día --</option>
                    @foreach (var dia in Model.DiasSemana)
                    {
                        <option value="@dia.Valor">@dia.Nombre</option>
                    }
                </select>
                <span asp-validation-for="DiaSemana" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="HoraInicio" class="form-label"></label>
                <input asp-for="HoraInicio" type="time" class="form-control" />
                <span asp-validation-for="HoraInicio" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="HoraFin" class="form-label"></label>
                <input asp-for="HoraFin" type="time" class="form-control" />
                <span asp-validation-for="HoraFin" class="text-danger"></span>
            </div>

            <div class="mb-3 form-check">
                <input asp-for="EsDiaLibre" class="form-check-input" type="checkbox" />
                <label asp-for="EsDiaLibre" class="form-check-label"></label>
            </div>

            <div class="mb-3">
                <input type="submit" value="Crear" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Volver a la lista</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
